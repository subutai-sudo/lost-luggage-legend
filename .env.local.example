# Affiliate Network Configuration
# Copy this file to .env.local and fill in your actual affiliate IDs

# ShareASale
NEXT_PUBLIC_SHAREASALE_ID=your_shareasale_id
NEXT_PUBLIC_SHAREASALE_MERCHANT_ID=your_default_merchant_id

# Awin
NEXT_PUBLIC_AWIN_ID=your_awin_affiliate_id
NEXT_PUBLIC_AWIN_ADVERTISER_ID=your_default_advertiser_id

# Amazon Associates
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=your_amazon_tag

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://lostluggagelegends.com
NEXT_PUBLIC_SITE_NAME="Lost Luggage Legends"

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=your_google_tag_manager_id
NEXT_PUBLIC_GA_ID=your_google_analytics_id
